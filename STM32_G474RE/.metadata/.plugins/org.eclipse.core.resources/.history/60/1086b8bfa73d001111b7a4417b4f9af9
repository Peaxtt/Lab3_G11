/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_TIM1_Init();
  MX_TIM3_Init();
  MX_LPUART1_UART_Init();
  MX_TIM6_Init();
  /* USER CODE BEGIN 2 */
  /*initialize Discrete Kalman matrix*/
  //void Kalman_Init(KalmanFilter_t *kf, float initial_position, float dt, float processDisplacementNoise, float measurementNoise,float velocityState,float processVelocitytNoise);

  Kalman_Init(&StaticKalman_01_167, 0.0f, 0.0f,0.01f,0.167f,0.0f,0.0f);
  Kalman_Init(&StaticKalman_01_00167, 0.0f, 0.0f,0.01f,0.00167f,0.0f,0.0f);
  Kalman_Init(&StaticKalman_01_0000167, 0.0f, 0.0f,0.01f,0.0000167f,0.0f,0.0f);

  Kalman_Init(&StaticKalman_00001_167, 0.0f, 0.0f,0.00001f,0.167f,0.0f,0.0f);
  Kalman_Init(&StaticKalman_00001_00167, 0.0f, 0.0f,0.00001f,0.00167f,0.0f,0.0f);
  Kalman_Init(&StaticKalman_00001_0000167, 0.0f, 0.0f,0.00001f,0.0000167f,0.0f,0.0f);

  Kalman_Init(&StaticKalman_00000001_167, 0.0f, 0.0f,0.00000001f,0.167f,0.0f,0.0f);
  Kalman_Init(&StaticKalman_00000001_00167, 0.0f, 0.0f,0.00000001f,0.00167f,0.0f,0.0f);
  Kalman_Init(&StaticKalman_00000001_0000167, 0.0f, 0.0f,0.00000001f,0.0000167f,0.0f,0.0f);



  //  HAL_UART_Transmit(&hlpuart1, text, 11, 10);
    HAL_TIM_Base_Start(&htim3);
    /* 2. Enable the PWM signal output on Timer 3, Channel 1 */
    HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_1);

    HAL_TIM_Base_Start(&htim1);
    HAL_TIM_IC_Start(&htim1, TIM_CHANNEL_1);
    HAL_TIM_IC_Start(&htim1, TIM_CHANNEL_2);

//    observation timer
    HAL_TIM_Base_Start_IT(&htim6);
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
	  DummyTask(); // LED heartbeat

	  if (run_sensor_task == 1)
	      {
	          // 1. Immediately lower the flag so we don't double-trigger
	          run_sensor_task = 0;

	          // 2. Read the raw sensor data
	          rawDistance = ultrasonicRawRead();

	          // 3. Filter the data! (measurement = raw, u = 0, dt = 0.05)
	          StaticKalmancleanDistance_01_167 = Kalman_Update(&StaticKalman_01_167, rawDistance, 0.0f, 0.0f);
	          StaticKalmancleanDistance_01_00167 = Kalman_Update(&StaticKalman_01_00167, rawDistance, 0.0f, 0.0f);
	          StaticKalmancleanDistance_01_0000167 = Kalman_Update(&StaticKalman_01_0000167, rawDistance, 0.0f, 0.0f);

	          StaticKalmancleanDistance_00001_167 = Kalman_Update(&StaticKalman_00001_167, rawDistance, 0.0f, 0.0f);
	          StaticKalmancleanDistance_00001_00167 = Kalman_Update(&StaticKalman_00001_00167, rawDistance, 0.0f, 0.0f);
	          StaticKalmancleanDistance_00001_0000167 = Kalman_Update(&StaticKalman_00001_0000167, rawDistance, 0.0f, 0.0f);
	          StaticKalmancleanDistance_00000001_167 = Kalman_Update(&StaticKalman_00000001_167, rawDistance, 0.0f, 0.0f);
	          StaticKalmancleanDistance_00000001_00167 = Kalman_Update(&StaticKalman_00000001_00167, rawDistance, 0.0f, 0.0f);
	          StaticKalmancleanDistance_00000001_0000167 = Kalman_Update(&StaticKalman_00000001_0000167, rawDistance, 0.0f, 0.0f);



	          // OPTIONAL: You can also look at the velocity!
	          // float currentVelocity = mySensorFilter.x_data[1];

	          // 4. Transmit the clean distance to Simulink using the custom UART function
	          TransmitDistancePacket(rawDistance,StaticKalmancleanDistance_01_167,StaticKalmancleanDistance_01_00167,StaticKalmancleanDistance_01_0000167,StaticKalmancleanDistance_00001_167,
	        		  StaticKalmancleanDistance_00001_00167,StaticKalmancleanDistance_00001_0000167,StaticKalmancleanDistance_00000001_167,StaticKalmancleanDistance_00000001_00167,
					  StaticKalmancleanDistance_00000001_0000167);
	      }
  }
  /* USER CODE END 3 */
}

