void TransmitDistancePacket(float distance)
{
    // 1. We can define the union right here locally
    typedef union {
        float value;
        uint8_t bytes[4];
    } FloatUnion;
    typedef union {
            float value;
            uint8_t bytes[4];
        } FloatUniontest;
    FloatUnion dataToSend;
    FloatUniontest datatest;
    dataToSend.value = distance; // Load the float
    datatest.value = distance/2.0f;
    // 2. Create a local buffer for the packet
    uint8_t packet[12];

    // 3. Assemble the packet
	packet[0] = 0x7E;               // Header 1
	packet[1] = 0x7E;               // Header 2
	packet[2] = dataToSend.bytes[0]; // Float Byte 1
	packet[3] = dataToSend.bytes[1]; // Float Byte 2
	packet[4] = dataToSend.bytes[2]; // Float Byte 3
	packet[6] = dataToSend.bytes[3];
	packet[7] = datatest.bytes[0]; // Float Byte 1
	packet[8] = datatest.bytes[1]; // Float Byte 2
	packet[9] = datatest.bytes[2]; // Float Byte 3
	packet[10] = datatest.bytes[3]; // Float Byte 4
	packet[11] = 0x03;               // Terminator 1
	packet[12] = 0x03;               // Terminator 2

    // 4. Transmit via LPUART1
    HAL_UART_Transmit(&hlpuart1, packet, 13, 10);
}

